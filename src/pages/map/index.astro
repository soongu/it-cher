---
import Base from '../../layouts/Base.astro'
import Crumbs from '../../components/Crumbs.astro'
import { codeBuckets, cpeSubjects, sqldParts } from '../../lib/content.mjs'
import ProgressGroup from '../../components/ProgressGroup.astro'
import Glyph from '../../components/Glyph.astro'

// 전체 커리큘럼을 한 화면에 — 코딩 9분야를 '학습 순서 레인'으로(메인), 자격증은 보조 섹션으로.
// 그룹별 진도 요약 + 이어보기는 localStorage 런타임(Base.astro)이 채우고, 온보딩(itcher:onboard:v1) 추천은
// 이 페이지 하단 런타임이 레인에 .is-rec/.is-top 강조를 입힌다(정적 사이트 → 프로그레시브 인핸스먼트).

// ── 코딩: 9분야 학습-순서 레인(데이터 파생, content.mjs SSOT) ──
// dir 토픽은 0강이어도 /code/{bucket}/{topic}/ 로드맵 페이지가 있어 클릭 가능(막다른 길 아님).
const buckets = codeBuckets()
const codeLanes = buckets.map((b, i) => ({
  n: i + 1, slug: b.slug, label: b.label, sub: b.subtitle, glyph: b.glyph,
  live: b.status === 'live',
  // 라이브 토픽(강의>0) = 진도 카드 / 준비중 토픽(0강) = 로드맵 칩. 둘로 갈라 렌더.
  liveTopics: b.topics.filter((t) => t.dir && t.lectures.length > 0).map((t) => {
    const href = `/code/${b.slug}/${t.slug}/`
    return {
      label: t.label, href, count: t.lectures.length,
      // 진도키 = 강 상세 href(트레일링슬래시) — 강 상세의 data-lec-key·이어보기와 동일 규칙으로 정합.
      items: t.lectures.map((l) => ({ h: `${href}${l.slug}/`, l: l.title })),
    }
  }),
  soonTopics: b.topics.filter((t) => t.dir && t.lectures.length === 0).map((t) => ({
    label: t.label, href: `/code/${b.slug}/${t.slug}/`,
  })),
}))
const liveCount = codeLanes.filter((l) => l.live).length
const soonCount = codeLanes.length - liveCount

// ── 자격증(보조): deck-ready 과목 + SQLD 모의고사 ──
const cpe = cpeSubjects()
const sqld = sqldParts()
const sqldItems = sqld.map((p) => ({ h: `/cert/sqld/practice/${p.slug}/`, l: `${p.num}부 · ${p.topic}` }))
const cpeCards = cpe
  .map((s) => ({
    href: `/cert/cpe/written/theory/${s.slug}/`, title: s.label,
    items: s.lectures.filter((l) => l.deck).map((l) => ({ h: `/cert/cpe/written/theory/${s.slug}/${l.slug}/`, l: `${l.num}강 · ${l.topic}` })),
  }))
  .filter((c) => c.items.length > 0)
---
<Base title="전체 커리큘럼 한눈에 — it-cher" desc="코딩 9개 분야를 배우는 순서대로 한 화면에. 자기 위치와 진도를 확인하고 이어서 학습하세요.">
  <div class="page">
    <Crumbs trail={[{ label: '전체 커리큘럼' }]} />
    <div class="page-head">
      <h1>전체 커리큘럼 한눈에</h1>
      <p class="lede">코딩 9개 분야를 <b>배우는 순서대로</b> 펼쳐 뒀어요. 위에서부터 따라오면 돼요. 한 번 본 강의는 자동으로 체크되고, 다음에 이어서 볼 수 있어요.</p>
    </div>

    {/* 최근 본 강의 이어보기 — localStorage 에 기록이 있을 때만 노출(런타임이 has-last 부여) */}
    <div class="resume-hero" data-resume-last>
      <span class="rh-ico">▶</span>
      <div class="rh-body">
        <div class="rh-eyebrow">이어서 보기</div>
        <div class="rh-title" data-resume-text>최근 본 강의</div>
      </div>
      <a class="btn rh-cta" data-resume-link href="/start/">이어보기 →</a>
    </div>

    {/* 온보딩(/start) 진단 결과 반영 안내 — 진단이 있을 때만 런타임이 노출(무진단/무JS면 hidden). */}
    <a class="map-onboard" data-map-onboard href="/start/" hidden>
      <span class="mo-ico" aria-hidden="true">✦</span>
      <span class="mo-txt"><b>진단 결과를 반영했어요</b> — 추천 분야의 번호에 색을 입혔어요.</span>
      <span class="mo-go">다시 진단 →</span>
    </a>

    {/* ===== 코딩: 9분야 학습 지도(메인) ===== */}
    <div class="section-head">
      <div>
        <h2 class="t-h2"><Glyph name="code" cls="h2-gi" /> 코딩 9개 분야</h2>
        <p>입문부터 순서대로. 지금 <b>{liveCount}개 분야</b>가 열려 있고, 나머지 {soonCount}개는 커리큘럼 로드맵으로 미리 볼 수 있어요.</p>
      </div>
    </div>

    <div class="map-path">
      {codeLanes.map((lane) => (
        <section class:list={['map-lane', { 'is-soon': !lane.live }]} data-map-bucket={lane.slug}>
          <div class="lane-head">
            <span class="lane-step" aria-hidden="true">{lane.n}</span>
            <span class="lane-ico is-cool"><Glyph name={lane.glyph} /></span>
            <div class="lane-headtxt">
              <div class="lane-title">
                <a href={`/code/${lane.slug}/`}>{lane.label}</a>
                {lane.live
                  ? <span class="badge badge--live"><span class="dot"></span>운영</span>
                  : <span class="badge badge--planned"><span class="dot"></span>준비중</span>}
                <span class="lane-rec">✦ 추천 출발점</span>
              </div>
              <div class="lane-sub">{lane.sub}</div>
            </div>
          </div>

          <div class="lane-topics">
            {lane.liveTopics.map((t) => (
              <div class="map-topic">
                <div class="mt-head">
                  <a class="mt-title" href={t.href}>{t.label}</a>
                  <span class="mt-count">{t.count}강</span>
                </div>
                <ProgressGroup items={t.items} unit="강" />
              </div>
            ))}
            {lane.soonTopics.length > 0 && (
              <div class="lane-soon">
                <span class="lane-soon-label">{lane.live ? '다음 단계 · 로드맵' : '커리큘럼 로드맵'}</span>
                <div class="lane-soon-chips">
                  {lane.soonTopics.map((t) => (
                    <a class="soon-chip" href={t.href}>{t.label}<span class="sc-arrow" aria-hidden="true">→</span></a>
                  ))}
                </div>
              </div>
            )}
          </div>
        </section>
      ))}
    </div>

    {/* ===== 자격증(보조) ===== */}
    <div class="section-head map-cert-head">
      <div>
        <h2 class="t-h2"><Glyph name="graduation" cls="h2-gi" /> 자격증도 준비한다면</h2>
        <p>시험 합격이 목표라면. 핵심만 압축한 정리 슬라이드로.</p>
      </div>
    </div>
    <div class="grid grid-2">
      {cpeCards.map((c) => (
        <div class="card map-card" data-map-cert="cpe">
          <div class="mc-head">
            <span class="mc-ico"><Glyph name="book" /></span>
            <div><div class="mc-title"><a href={c.href}>{c.title}</a></div><div class="mc-sub">정보처리기사 필기 · 슬라이드</div></div>
            <span class="mc-total">{c.items.length}강</span>
          </div>
          <ProgressGroup items={c.items} unit="강" />
        </div>
      ))}
      {sqldItems.length > 0 && (
        <div class="card map-card" data-map-cert="sqld">
          <div class="mc-head">
            <span class="mc-ico"><Glyph name="database" /></span>
            <div><div class="mc-title"><a href="/cert/sqld/practice/">SQLD 벼락치기</a></div><div class="mc-sub">SQL 개발자 · 슬라이드</div></div>
            <span class="mc-total">{sqldItems.length}부</span>
          </div>
          <ProgressGroup items={sqldItems} unit="부" />
        </div>
      )}
    </div>

    <p class="map-note">진도는 가입 없이 <b>이 브라우저에만</b> 저장돼요. 시크릿 창이나 다른 기기에서는 따로 표시됩니다.</p>
  </div>

  {/* 온보딩 맞춤 강조(Phase 3): /start 진단값(itcher:onboard:v1)으로 추천 분야 레인에 .is-rec(top=.is-top) 강조.
      ITcherNav 와 동일 선언적 계약 — [data-map-bucket]·[data-map-cert]·[data-map-onboard]. 추천 슬러그는 신뢰 못 할
      입력이라 요소를 순회하며 indexOf 로 매칭(셀렉터를 외부 문자열로 만들지 않음). 무진단/무JS면 전체가 그대로 노출(막다른 길 0). */}
  <script is:inline>
    (function () {
      var KEY = 'itcher:onboard:v1';
      function load() { try { var v = JSON.parse(localStorage.getItem(KEY)); return v && v.v === 1 ? v : null; } catch (e) { return null; } }
      function apply() {
        var data = load();
        var rec = (data && Array.isArray(data.recCode)) ? data.recCode : [];
        var recCert = (data && Array.isArray(data.recCert)) ? data.recCert : [];
        document.querySelectorAll('[data-map-bucket]').forEach(function (el) {
          el.classList.remove('is-rec', 'is-top');
          var i = rec.indexOf(el.getAttribute('data-map-bucket'));
          if (i >= 0) { el.classList.add('is-rec'); if (i === 0) el.classList.add('is-top'); }
        });
        document.querySelectorAll('[data-map-cert]').forEach(function (el) {
          el.classList.toggle('is-rec', recCert.indexOf(el.getAttribute('data-map-cert')) >= 0);
        });
        var note = document.querySelector('[data-map-onboard]');
        if (note) note.hidden = !(rec.length || recCert.length);
      }
      window.ITcherMap = { apply: apply };
      function boot() { apply(); }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot); else boot();
      window.addEventListener('storage', function (e) { if (e.key === KEY) apply(); });
    })();
  </script>
</Base>

<style>
  /* 코딩 학습 지도 — 9개 분야를 학습 순서 '레인'으로. 번호 스텝(1~9) + 세로 레일로 '순서대로'를 시각화. */
  .map-path { display: flex; flex-direction: column; gap: var(--sp-6); }
  .map-lane {
    position: relative; padding: 8px 8px 8px 56px; border-radius: var(--r-xl);
    transition: background var(--dur-fast) var(--ease), box-shadow var(--dur-fast) var(--ease);
  }
  /* 스텝을 잇는 세로 레일(장식) — 다음 레인 스텝까지 이어 '학습 경로' 느낌. 마지막 레인은 생략. */
  .map-lane::before {
    content: ""; position: absolute; left: 25px; top: 10px; bottom: calc(-1 * var(--sp-6));
    width: 2px; background: var(--border-default); z-index: 0;
  }
  .map-lane:last-child::before { display: none; }

  .lane-head { display: flex; align-items: center; gap: var(--sp-3); margin-bottom: var(--sp-3); }
  /* 번호 스텝 — 기본은 차분한 중립(순서만), 추천(.is-rec)일 때만 코랄로 '켜진다'. */
  .lane-step {
    position: absolute; left: 8px; top: 8px; width: 36px; height: 36px; flex: none;
    border-radius: var(--r-full); display: grid; place-items: center; z-index: 1;
    font-weight: var(--fw-bold); font-size: var(--fs-sm);
    background: var(--surface-subtle); color: var(--text-strong); border: 1.5px solid var(--border-default);
  }
  .lane-ico {
    width: 38px; height: 38px; flex: none; border-radius: var(--r-md);
    display: grid; place-items: center; background: var(--info-bg); color: var(--info);
  }
  .lane-ico :global(.gi) { width: 21px; height: 21px; }
  .lane-headtxt { min-width: 0; }
  .lane-title { display: flex; align-items: center; flex-wrap: wrap; gap: 8px; }
  .lane-title a { font-weight: var(--fw-bold); font-size: var(--fs-h4); color: var(--text-strong); }
  .lane-title a:hover { color: var(--brand-text); }
  .lane-sub { font-size: var(--fs-sm); color: var(--text-muted); margin-top: 2px; }
  .lane-rec {
    display: none; align-items: center; gap: 4px; font-size: var(--fs-xs); font-weight: var(--fw-bold);
    color: #fff; background: var(--brand); padding: 2px 9px; border-radius: var(--r-full);
  }

  /* 준비중 레인 — 도메인 아이콘만 톤다운(상태는 배지가 말해줌). */
  .map-lane.is-soon .lane-ico { background: var(--surface-subtle); color: var(--text-faint); }

  /* 온보딩 추천(런타임). 과하지 않게: 추천 경로의 '번호'만 코랄로 켜고, #1만 살짝 강조 + 배지. 배경 범람 없음. */
  .map-lane.is-rec .lane-step { background: var(--brand); color: #fff; border-color: var(--brand); }
  .map-lane.is-top { background: linear-gradient(180deg, var(--brand-tint), transparent 68%); box-shadow: inset 0 0 0 1px var(--brand-tint-bd); }
  .map-lane.is-top .lane-step { box-shadow: 0 0 0 4px var(--brand-tint); }
  .map-lane.is-top .lane-rec { display: inline-flex; }

  /* 레인 안 콘텐츠 — 라이브 토픽=진도 카드(전체폭 스택) · 준비중 토픽=로드맵 칩 줄. */
  .lane-topics { display: flex; flex-direction: column; gap: var(--sp-4); }
  .map-topic {
    border: 1px solid var(--border-default); border-radius: var(--r-lg);
    background: var(--surface-card); padding: var(--sp-4);
    display: flex; flex-direction: column; gap: var(--sp-3);
  }
  .map-topic .mt-head { display: flex; align-items: center; gap: 8px; }
  .map-topic .mt-title { font-weight: var(--fw-bold); color: var(--text-strong); text-decoration: none; }
  .map-topic a.mt-title:hover { color: var(--brand-text); }
  .map-topic .mt-count { margin-left: auto; font-size: var(--fs-xs); color: var(--text-faint); white-space: nowrap; }
  /* ProgressGroup 은 자체 카드(테두리·배경)를 가져 → 레인 카드 안에선 카드-인-카드가 된다. 평탄화해 단일 카드로. */
  .map-topic :global(.prog-summary) { border: none; background: none; padding: 0; border-radius: 0; }

  /* 준비중 토픽 = 컴팩트 로드맵 칩(점선 → hover 채움). 큰 빈 박스 대신 가벼운 미리보기. 막다른 길 아님. */
  .lane-soon { display: flex; flex-direction: column; gap: 8px; }
  .lane-soon-label { font-size: var(--fs-xs); font-weight: var(--fw-semibold); letter-spacing: .02em; color: var(--text-faint); }
  .lane-soon-chips { display: flex; flex-wrap: wrap; gap: var(--sp-2); }
  .soon-chip {
    display: inline-flex; align-items: center; gap: 7px; padding: 8px 14px;
    border: 1px dashed var(--border-default); border-radius: var(--r-full); background: var(--surface-subtle);
    font-size: var(--fs-sm); font-weight: var(--fw-medium); color: var(--text-default); text-decoration: none;
    transition: border-color var(--dur-fast) var(--ease), background var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }
  .soon-chip:hover { border-style: solid; border-color: var(--brand); background: var(--brand-tint); color: var(--brand-text); }
  .soon-chip .sc-arrow { color: var(--text-faint); transition: color var(--dur-fast) var(--ease); }
  .soon-chip:hover .sc-arrow { color: var(--brand-text); }

  /* 온보딩 반영 안내 배너 */
  .map-onboard {
    display: flex; align-items: center; gap: var(--sp-3); margin-bottom: var(--sp-6);
    padding: var(--sp-3) var(--sp-4); border: 1px solid var(--brand-tint-bd); border-radius: var(--r-lg);
    background: var(--brand-tint); color: inherit; text-decoration: none;
  }
  .map-onboard[hidden] { display: none; }
  .map-onboard:hover { border-color: var(--brand); }
  .map-onboard .mo-ico { color: var(--brand-text); font-weight: var(--fw-bold); }
  .map-onboard .mo-txt { font-size: var(--fs-sm); color: var(--text-default); }
  .map-onboard .mo-txt b { color: var(--text-strong); }
  .map-onboard .mo-go { margin-left: auto; font-size: var(--fs-sm); font-weight: var(--fw-semibold); color: var(--brand-text); white-space: nowrap; }

  /* 자격증(보조) 섹션은 코딩 다음, 시각적으로 한 단계 낮게. */
  .map-cert-head { margin-top: var(--sp-8); }
  .map-note { margin-top: var(--sp-7); font-size: var(--fs-sm); color: var(--text-muted); }
  .map-note b { color: var(--text-strong); }
</style>
