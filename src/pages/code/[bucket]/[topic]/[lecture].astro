---
import Base from '../../../../layouts/Base.astro'
import Crumbs from '../../../../components/Crumbs.astro'
import { codeBuckets, loadDoc } from '../../../../lib/content.mjs'
import { render, titleShort } from '../../../../lib/markdown.mjs'
import { FUNNELS } from '../../../../lib/links.mjs'
import FunnelCta from '../../../../components/FunnelCta.astro'
import Pager from '../../../../components/Pager.astro'
import LecProgress from '../../../../components/LecProgress.astro'
import LevelPrereq from '../../../../components/LevelPrereq.astro'

export function getStaticPaths() {
  const paths = []
  for (const b of codeBuckets()) {
    const dirTopics = b.topics.filter((t) => t.dir && t.lectures.length)
    for (const t of b.topics) {
      if (t.dir && t.lectures.length) {
        // 같은 토픽 정렬 배열의 앞뒤 강 → 페이저(막다른 길 방지). 토픽 경계는 넘지 않음.
        const mk = (x) => (x ? { href: `/code/${b.slug}/${t.slug}/${x.slug}/`, label: x.title } : null)
        // 토픽을 끝까지 본 학생에게 같은 버킷 '다음 토픽' 추천(퍼널전용 종료 방지).
        const nt = dirTopics[dirTopics.indexOf(t) + 1] || null
        const nextTopic = nt ? { href: `/code/${b.slug}/${nt.slug}/`, label: nt.label } : null
        t.lectures.forEach((l, i) => {
          paths.push({
            params: { bucket: b.slug, topic: t.slug, lecture: l.slug },
            props: {
              bucket: b.slug, topicSlug: t.slug, bucketLabel: b.label, topicLabel: t.label, lec: l,
              prev: mk(t.lectures[i - 1]), next: mk(t.lectures[i + 1]), nextTopic,
              index: i + 1, total: t.lectures.length,
              level: t.level, prereq: t.prereq, note: t.note,
            },
          })
        })
      }
    }
  }
  return paths
}

const { bucket, topicSlug, bucketLabel, topicLabel, lec, prev, next, nextTopic, index, total, level, prereq, note } = Astro.props
const lecKey = `/code/${bucket}/${topicSlug}/${lec.slug}/`
const doc = loadDoc(lec.file)

// 본문 렌더 + 헤딩 id 주입 + TOC 추출 (h2/h3)
// env.base = 토픽 URL 프리픽스 → 본문의 './dayNN-lecture.md' 상호참조를 사이트 경로로 재작성(V3).
const renderEnv = { base: `/code/${bucket}/${topicSlug}/` }
let lectureHtml = render(doc.body, renderEnv)
const toc = []
// 렌더된 heading HTML에서 태그를 벗긴 뒤, markdown-it가 escape한 엔티티(&quot; &lt; &gt; &amp;)를
// 실제 문자로 한 번 디코드한다. 이렇게 해야 {h.text} JSX 주입 시 Astro가 정확히 한 번만 escape하고
// 이중 이스케이프(브라우저에 &quot;/&lt;/&gt;가 리터럴 노출)가 사라진다. &amp;는 마지막에 풀어야 안전.
// 본문(set:html=lectureHtml)은 손대지 않으므로 정상 렌더 유지.
const decodeEntities = (s) => s
  .replace(/&quot;/g, '"')
  .replace(/&#39;|&#x27;/g, "'")
  .replace(/&lt;/g, '<')
  .replace(/&gt;/g, '>')
  .replace(/&amp;/g, '&')
lectureHtml = lectureHtml.replace(/<h([23])>([\s\S]*?)<\/h\1>/g, (_m, lvl, inner) => {
  const text = decodeEntities(inner.replace(/<[^>]+>/g, '')).trim()
  const id = `h-${toc.length}`
  toc.push({ lvl: Number(lvl), text, id })
  return `<h${lvl} id="${id}">${inner}</h${lvl}>`
})

// 답안 헤딩은 한 단계 강등(F33) — 답안 h1 이 강 제목 <h1> 과 동급으로 뜨지 않게(아웃라인 보정).
const answersHtml = lec.answersFile ? render(loadDoc(lec.answersFile).body, { ...renderEnv, shiftHeadings: 1 }) : null
const title = doc.hasH1 ? doc.title : lec.title
// 읽는 시간(한글 ~300자/분)
const minutes = Math.max(1, Math.round(doc.body.replace(/\s/g, '').length / 300))
// 구조화데이터: 무료 Course(본문 색인과 무관, 제목/메타만). 전역 Org/WebSite 위에 추가됨.
const course = {
  '@context': 'https://schema.org', '@type': 'Course',
  name: `${title} — ${topicLabel}`,
  description: `${bucketLabel} · ${topicLabel} — ${title}`,
  url: `https://it-cher.com${lecKey}`,
  inLanguage: 'ko-KR', isAccessibleForFree: true, timeRequired: `PT${minutes}M`,
  provider: { '@type': 'EducationalOrganization', name: 'it-cher', '@id': 'https://it-cher.com/#org' },
}
---
<Base title={`${titleShort(title)} — ${topicLabel} · it-cher`} desc={`${bucketLabel} · ${topicLabel} — ${title}`} ogType="article" jsonLd={course}>
  <div class="doc-layout">
    <!-- left rail -->
    <div class="doc-rail">
      <button class="rail-btn" data-top title="맨 위로"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 19V5M5 12l7-7 7 7"/></svg></button>
      <button class="rail-btn" data-copy title="링크 복사"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg></button>
    </div>

    <!-- main (data-pagefind-body: 코딩 강의 본문을 검색 색인에 포함) -->
    <article class="doc-main" data-pagefind-body>
      <Crumbs trail={[{ href: '/code/', label: '코딩' }, { href: `/code/${bucket}/`, label: bucketLabel }, { href: `/code/${bucket}/${topicSlug}/`, label: topicLabel }, { label: title }]} />
      <header class="doc-head">
        <div class="meta-row" data-pagefind-ignore>
          <span class="badge badge--doc">문서</span>
          <span class="t-xs t-muted">읽는 데 {minutes}분 · {lec.id}</span>
        </div>
        <h1>{title}</h1>
        <div class="doc-byline" data-pagefind-ignore><span class="av">홍</span><span>홍순구 · {bucketLabel}</span></div>
      </header>

      {/* H3(F04): 모바일(≤1000px)에선 우측 목차(.doc-toc)가 숨겨져 긴 문서를 스크롤만 해야 했음 →
          같은 toc 배열을 .doc-head 아래 접이식 목차로 노출(≥1001px display:none). 앵커는 #h-N(본문 헤딩 id) 재사용. */}
      {toc.length > 0 && (
        <details class="doc-toc-m" data-pagefind-ignore>
          <summary>목차 <span class="toc-m-count">{toc.length}</span></summary>
          <nav>
            {toc.map((h) => (
              <a href={`#${h.id}`} class={h.lvl === 3 ? 'sub' : undefined}>{h.text}</a>
            ))}
          </nav>
        </details>
      )}

      <LecProgress index={index} total={total} unit="강" groupLabel={topicLabel} lecKey={lecKey} lecLabel={title} />

      <LevelPrereq level={level} prereq={prereq} note={note} />

      <div class="doc" set:html={lectureHtml} />

      {answersHtml && (
        <div class="doc" style="margin-top: var(--sp-6);">
          <details class="answer">
            <summary>✅ 예시 답안<span class="answer-tag">정답 보기</span></summary>
            <div set:html={answersHtml} />
          </details>
        </div>
      )}

      <span data-lec-end aria-hidden="true"></span>
      <div data-pagefind-ignore><Pager prev={prev} next={next} list={{ href: `/code/${bucket}/${topicSlug}/`, label: topicLabel }} /></div>

      {/* 토픽 끝(다음 강 없음)에서 다음 토픽 추천 — 학습 동선이 퍼널보다 먼저(STUDENT-EXPERIENCE ⑤ 🟡) */}
      {!next && (nextTopic
        ? <a class="next-topic" href={nextTopic.href} data-pagefind-ignore>
            <span class="nt-eyebrow">이 토픽을 끝까지 봤어요 🎉 다음은</span>
            <span class="nt-title">{nextTopic.label} →</span>
          </a>
        : <a class="next-topic" href="/map/" data-pagefind-ignore>
            <span class="nt-eyebrow">이 토픽을 끝까지 봤어요 🎉</span>
            <span class="nt-title">다른 트랙도 둘러보기 →</span>
          </a>)}

      {/* 유료 퍼널은 1강에선 숨김(학습 먼저). 2강+에서만 노출 → 초반 CTA 빈도↓(STUDENT-EXPERIENCE ⑤ 🟡) */}
      {index > 1 && (
        <div class="cta-band" data-pagefind-ignore>
          <p class="eyebrow">더 배우려면</p>
          <h3 class="t-h3">실무 프로젝트까지 가고 싶다면</h3>
          <p>팀스파르타 백엔드 부트캠프에서 인스타그램 클론을 풀스택으로 완성합니다.</p>
          <div class="cta-row"><FunnelCta funnel={FUNNELS.sparta} label="팀스파르타 내일배움캠프" /></div>
        </div>
      )}
    </article>

    <!-- TOC -->
    {toc.length > 0 && (
      <nav class="doc-toc">
        <div class="toc-label">목차</div>
        {toc.map((h) => (
          <a href={`#${h.id}`} class={h.lvl === 3 ? 'sub' : undefined}>{h.text}</a>
        ))}
      </nav>
    )}
  </div>

  <script is:inline>
    (function () {
      var top = document.querySelector('[data-top]');
      if (top) top.addEventListener('click', function () { window.scrollTo({ top: 0, behavior: 'smooth' }); });
      var copy = document.querySelector('[data-copy]');
      if (copy) copy.addEventListener('click', function () {
        try { navigator.clipboard.writeText(location.href); copy.classList.add('ok'); setTimeout(function(){copy.classList.remove('ok');}, 1200); } catch (e) {}
      });
    })();

    // 우측 목차 스크롤스파이 — 현재 위치의 헤딩 TOC 링크 강조(JS 없으면 정적 링크로 그대로 동작).
    // scroll 이벤트 + rAF 스로틀로 매 스크롤 위치를 평가한다. IntersectionObserver(밴드 관찰)는
    // TOC 클릭 점프·빠른 스크롤처럼 밴드를 건너뛰면(미교차→미교차) 콜백이 안 떠 active 가 누락되므로 쓰지 않는다.
    (function () {
      var toc = document.querySelector('.doc-toc');
      if (!toc) return;
      var links = {};
      Array.prototype.forEach.call(toc.querySelectorAll('a[href^="#"]'), function (a) {
        links[a.getAttribute('href').slice(1)] = a;
      });
      var headings = Array.prototype.filter.call(
        document.querySelectorAll('.doc h2[id], .doc h3[id]'),
        function (h) { return links[h.id]; }
      );
      if (!headings.length) return;
      var current = null;
      function setActive(id) {
        if (id === current) return;
        current = id;
        for (var k in links) {
          if (k === id) { links[k].classList.add('active'); links[k].setAttribute('aria-current', 'true'); }
          else { links[k].classList.remove('active'); links[k].removeAttribute('aria-current'); }
        }
      }
      // 스티키 헤더(64px) 바로 아래 줄 기준으로, 그 위로 올라간 '마지막' 헤딩을 현재 섹션으로 본다.
      function compute() {
        var line = 64 + 16; // 헤더 64 + 여유 16
        var active = headings[0];
        for (var i = 0; i < headings.length; i++) {
          if (headings[i].getBoundingClientRect().top <= line) active = headings[i];
          else break;
        }
        setActive(active.id);
      }
      var ticking = false;
      function onScroll() {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(function () { ticking = false; compute(); });
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      compute(); // 초기 1회(로드 직후/해시 진입 대응)
    })();
  </script>
</Base>

<style>
  .doc-layout { display: grid; grid-template-columns: 56px minmax(auto, var(--w-doc)) 1fr; gap: var(--sp-6); max-width: 1180px; margin-inline: auto; padding: var(--sp-7) var(--sp-5) 0; align-items: start; }
  .doc-main { min-width: 0; }
  /* 앵커 점프 시 스티키 헤더(64px) 뒤로 제목이 가려지지 않게 여유 확보.
     헤딩은 set:html로 주입돼 scope 해시가 안 붙으므로 :global()로 한정(전역 오염 없이 .doc 안 헤딩만). */
  .doc :global(:is(h2, h3)[id]) { scroll-margin-top: 80px; }
  .doc-head { margin-bottom: var(--sp-6); padding-bottom: var(--sp-5); border-bottom: 1px solid var(--border-default); }
  .doc-head .meta-row { display:flex; align-items:center; gap:10px; margin-bottom: 14px; flex-wrap: wrap; }
  .doc-head .meta-row .t-xs { white-space: nowrap; }
  .doc-head h1 { font-size: var(--fs-h1); font-weight: var(--fw-bold); line-height: var(--lh-tight); letter-spacing: var(--ls-tight); color: var(--text-strong); margin: 0; text-wrap: balance; }
  .doc-byline { display:flex; align-items:center; gap:10px; margin-top: var(--sp-4); font-size: var(--fs-sm); color: var(--text-muted); }
  .doc-byline .av { width: 30px; height: 30px; border-radius: 50%; background: var(--brand-tint); border:1px solid var(--brand-tint-bd); display:grid; place-items:center; font-size: 13px; color: var(--brand-text); flex:none; }
  /* 목차가 화면보다 길면(헤딩 많은 강) 자체적으로 스크롤 — 뷰포트 높이에서 sticky top(84)+하단여유(24) 제외.
     overscroll-behavior:contain 으로 목차 끝에서 본문으로 스크롤이 새지 않게. 라벨은 스크롤 중에도 상단 고정. */
  .doc-toc { position: sticky; top: 84px; max-height: calc(100vh - 84px - var(--sp-5)); overflow-y: auto; overscroll-behavior: contain; scrollbar-width: thin; scrollbar-color: var(--border-strong) transparent; padding-right: 4px; }
  .doc-toc::-webkit-scrollbar { width: 8px; }
  .doc-toc::-webkit-scrollbar-thumb { background: var(--border-default); border-radius: 99px; }
  .doc-toc:hover::-webkit-scrollbar-thumb { background: var(--border-strong); }
  .doc-toc .toc-label { position: sticky; top: 0; z-index: 1; background: var(--surface-page); font-size: var(--fs-xs); font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--text-faint); margin-bottom: 10px; padding-bottom: 6px; }
  .doc-toc a { display:block; padding: 5px 0 5px 12px; border-left: 2px solid var(--border-default); color: var(--text-muted); font-size: var(--fs-sm); }
  .doc-toc a:hover { color: var(--text-strong); border-color: var(--brand); text-decoration:none; }
  .doc-toc a.active { color: var(--brand-text); border-color: var(--brand); font-weight: var(--fw-semibold); background: var(--brand-tint); }
  .doc-toc a.sub { padding-left: 24px; font-size: var(--fs-xs); }
  /* H3(F04): 모바일 전용 접이식 목차(데스크톱은 우측 .doc-toc, ≤1000px는 이것). 기본 숨김 → 아래 미디어쿼리에서 표시. */
  .doc-toc-m { display: none; margin: 0 0 var(--sp-5); border: 1px solid var(--border-default); border-radius: var(--r-lg); background: var(--surface-card); overflow: hidden; }
  .doc-toc-m > summary { cursor: pointer; list-style: none; display: flex; align-items: center; gap: 8px; padding: var(--sp-3) var(--sp-4); font-size: var(--fs-sm); font-weight: var(--fw-bold); color: var(--text-strong); }
  .doc-toc-m > summary::-webkit-details-marker { display: none; }
  .doc-toc-m > summary::before { content: "▸"; color: var(--brand-text); font-size: 11px; transition: transform .15s ease; }
  .doc-toc-m[open] > summary::before { transform: rotate(90deg); }
  .doc-toc-m .toc-m-count { margin-left: auto; color: var(--text-muted); font-weight: var(--fw-semibold); font-size: var(--fs-xs); }
  .doc-toc-m nav { display: flex; flex-direction: column; padding: 4px var(--sp-4) var(--sp-3); border-top: 1px solid var(--border-subtle); }
  .doc-toc-m nav a { padding: 8px 0 8px 12px; border-left: 2px solid var(--border-default); color: var(--text-muted); font-size: var(--fs-sm); }
  .doc-toc-m nav a:hover { color: var(--text-strong); border-color: var(--brand); text-decoration: none; }
  .doc-toc-m nav a.sub { padding-left: 24px; font-size: var(--fs-xs); }
  .doc-rail { position: sticky; top: 84px; display:flex; flex-direction: column; gap: 8px; align-items:flex-start; }
  .rail-btn { width: 40px; height: 40px; border-radius: var(--r-md); border:1px solid var(--border-default); background: var(--surface-card); color: var(--text-muted); display:grid; place-items:center; cursor:pointer; }
  .rail-btn:hover { color: var(--brand-text); border-color: var(--brand-tint-bd); background: var(--brand-tint); }
  .rail-btn.ok { color: var(--ok); border-color: var(--ok-border); background: var(--ok-bg); }

  .next-topic { display:flex; flex-direction:column; gap:4px; padding: var(--sp-5); margin: var(--sp-5) 0 var(--sp-6); border:1px solid var(--brand-tint-bd); border-radius: var(--r-lg); background: var(--brand-tint); }
  .next-topic:hover { text-decoration:none; border-color: var(--brand); }
  .next-topic .nt-eyebrow { font-size: var(--fs-xs); font-weight: var(--fw-bold); color: var(--brand-text); }
  .next-topic .nt-title { font-size: var(--fs-h4); font-weight: var(--fw-bold); color: var(--text-strong); }

  /* H4(V2): 모바일(≤1000px) 1열 + 좌측 rail·우측 목차 숨김. 위 .doc-rail{display:flex}·.doc-toc{position:sticky}
     보다 반드시 뒤(소스 후순위)에 둔다 — 동일 특이도라 앞에 두면 그 규칙들이 덮어 375px 에서 rail 이 본문 위에 노출됐다. */
  @media (max-width: 1000px){ .doc-layout { grid-template-columns: 1fr; } .doc-toc, .doc-rail { display: none; } .doc-toc-m { display: block; } }
</style>
