---
import Base from '../../layouts/Base.astro'
import Crumbs from '../../components/Crumbs.astro'
import { codeBuckets } from '../../lib/content.mjs'
import { FUNNELS } from '../../lib/links.mjs'
import FunnelCta from '../../components/FunnelCta.astro'
import Glyph from '../../components/Glyph.astro'
const buckets = codeBuckets()
const bucketDocs = (b) => b.topics.reduce((m, t) => m + (t.lectures?.length || 0), 0)
// 버킷이 품은 토픽들의 기술 로고(자바·스프링·JS). 목표 이모지 옆에 작게 클러스터로 노출 → '무엇을 배우는지' 즉시 전달.
const bucketIcons = (b) => b.topics.filter((t) => t.icon).map((t) => ({ src: t.icon, label: t.label }))
---
<Base title="코딩 — 분야별 학습 지도 · it-cher" desc="분야별로 배우는 코딩 강의. 기초소양·언어·웹·백엔드·데이터·AI 등 9개 트랙. 입문부터 순서대로.">
  <div class="page">
    <Crumbs trail={[{ label: '코딩' }]} />
    <div class="page-head">
      <h1>코딩</h1>
      <p class="lede">분야별 학습 지도예요. 입문이라면 위에서부터 순서대로 따라오면 돼요. 기술 이름은 아직 몰라도 괜찮아요.</p>
    </div>

    <div class="grid grid-4">
      {buckets.map((b) => {
        const docs = bucketDocs(b)
        const icons = bucketIcons(b)
        const live = b.status === 'live'
        const techRow = icons.length > 0 && (
          <div class="tech-row">{icons.map((ic) => <img class="tech-chip" src={ic.src} alt={ic.label} width="18" height="18" loading="lazy" />)}</div>
        )
        // 0강 분류도 클릭 가능 — 준비중 로드맵 페이지로(막다른 길 금지). 배지·메타로 운영/준비중만 구분.
        return (
          <a class="card card--link cat-card" href={`/code/${b.slug}/`}>
            <div class="cat-top"><div class="cat-lead"><div class="cat-ico is-cool"><Glyph name={b.glyph} /></div>{techRow}</div>
              {live
                ? <span class="badge badge--live"><span class="dot"></span>운영</span>
                : <span class="badge badge--planned"><span class="dot"></span>예정</span>}</div>
            <div><div class="cat-title">{b.label}</div><div class="cat-sub">{b.subtitle}</div></div>
            <div class="cat-meta">{live ? `문서 ${docs}` : '준비중 · 로드맵'}</div>
          </a>
        )
      })}
    </div>

    <div class="cta-band">
      <p class="eyebrow">더 배우려면</p>
      <h3 class="t-h3">개발, 끝까지 배우고 싶다면</h3>
      <p>무료 자료로 감 잡았다면 팀스파르타 백엔드 부트캠프에서 인스타그램 클론을 풀스택으로 완성합니다.</p>
      <div class="cta-row"><FunnelCta funnel={FUNNELS.sparta} label="팀스파르타 내일배움캠프" /></div>
    </div>
  </div>
</Base>
