---
import Base from '../../../layouts/Base.astro'
import Crumbs from '../../../components/Crumbs.astro'
import { certTrack, cpeSubjects, cpeFirstReady } from '../../../lib/content.mjs'
import { FUNNELS } from '../../../lib/links.mjs'
import FunnelCta from '../../../components/FunnelCta.astro'
import HubCard from '../../../components/HubCard.astro'

const cpe = certTrack('cpe')
const subjects = cpeSubjects()
const first = cpeFirstReady() // F29: 첫 deck-ready 강 딥링크(단일 선택지 허브 건너뛰기)
const deckCount = subjects.reduce((n, s) => n + s.lectures.filter((l) => l.deck).length, 0)
const meta = {
  written: `이론 5과목 · 슬라이드 ${deckCount}개`,
  practical: '곧 공개',
}
---
<Base title="정보처리기사 — 필기 · 실기 · it-cher" desc="정보처리기사 필기와 실기. 필기 이론 5과목 슬라이드를 무료로 학습하세요.">
  <div class="page">
    <Crumbs trail={[{ href: '/cert/', label: '자격증' }, { label: '정보처리기사' }]} />
    <div class="page-head">
      <h1>정보처리기사</h1>
      <p class="lede">필기와 실기로 나뉩니다. 지금은 <b>필기 이론 5과목</b>이 공개돼 있어요. 시작할 시험을 고르세요.</p>
    </div>

    {/* F29: 살아있는 선택지가 1개뿐인 허브(필기→이론→과목)를 건너뛰는 바로 시작 딥링크 — 첫 강까지 클릭 단축. */}
    {first && (
      <a class="hub-start" href={first.href}>
        <span class="hs-go">바로 시작</span>
        <span class="hs-main">필기 이론 {first.num}강부터 바로 시작 <span class="hs-arr">→</span></span>
        <span class="hs-sub">{first.subjectLabel} · 슬라이드로 학습</span>
      </a>
    )}

    <div class="grid grid-2">
      {cpe.children.map((c) => (
        <HubCard href={c.href} glyph={c.glyph} title={c.label} sub={c.sub} status={c.status} meta={meta[c.slug]} />
      ))}
    </div>

    <div class="cta-band">
      <p class="eyebrow">합격까지</p>
      <h3 class="t-h3">정처기, 혼자 막막하다면</h3>
      <p>초개인화 학습앱 Klue와 에듀윌 온라인강의로 합격까지 이어가세요.</p>
      {/* F22: 준비중 Klue 동안은 라이브 채널(에듀윌)을 primary·앞으로. Klue 런칭(comingSoon 제거) 시 자동 복귀. */}
      <div class="cta-row">{FUNNELS.klue.comingSoon
        ? <><FunnelCta funnel={FUNNELS.eduwill} label="에듀윌 강의" /><FunnelCta funnel={FUNNELS.klue} label="Klue 앱" /></>
        : <><FunnelCta funnel={FUNNELS.klue} label="Klue 앱" /><FunnelCta funnel={FUNNELS.eduwill} label="에듀윌 강의" class="btn btn--secondary" /></>}</div>
    </div>
  </div>
</Base>

<style>
  /* F29: 첫 강 바로 시작 딥링크 — 코랄 틴트 카드(허브 그리드 위, 단일 선택지 건너뛰기) */
  .hub-start {
    display: grid; gap: 4px; margin-bottom: var(--sp-5);
    padding: var(--sp-4) var(--sp-5);
    background: var(--brand-tint); border: 1px solid var(--brand-tint-bd); border-radius: var(--r-lg);
    text-decoration: none; transition: border-color .15s ease, transform .15s ease;
  }
  .hub-start:hover { border-color: var(--brand); text-decoration: none; transform: translateY(-1px); }
  .hub-start .hs-go { font-size: var(--fs-xs); font-weight: var(--fw-bold); letter-spacing: .06em; text-transform: uppercase; color: var(--brand-text); }
  .hub-start .hs-main { font-size: var(--fs-h4); font-weight: var(--fw-bold); color: var(--text-strong); }
  .hub-start .hs-arr { display: inline-block; color: var(--brand-text); transition: transform .15s ease; }
  .hub-start:hover .hs-arr { transform: translateX(3px); }
  .hub-start .hs-sub { font-size: var(--fs-sm); color: var(--text-muted); }
</style>
