---
// 자격증(슬라이드-only) 학습 안내 — 학생경험 🟠 항목 3.
// 코딩 트랙엔 예시답안(details)이 있지만 자격증은 슬라이드뿐이라 혼자 학습 장치가 부족하다.
// 이 컴포넌트는 ①"이 강에서 배우는 것"(주제/트랙 = 제목·메타에서만 구성, 강의대본 본문 비노출 — 불변식 #2)
// ②"슬라이드만으로 공부하는 법" 5단계 가이드(details)를 제공한다.
// 색인 주의: cpe/sqld 페이지에서 data-pagefind-body 는 slide-head 한 곳뿐이고 이 블록은 그 바깥이라
//   자동으로 검색 색인에서 제외된다(매 페이지 반복되는 보일러플레이트라 색인하면 검색이 더러워짐).
//   props: topic(핵심 주제) · context(트랙·과목 라벨) · tip(시험별 한 줄 조언, 선택)
//          open(details 기본 펼침 — 그룹 첫 강만 true 권장) · eduwill(에듀윌 가벼운 언급, cpe만)
// 퍼널 URL은 links.mjs(FUNNELS) SSOT 참조 — 여기서 재정의하지 않음.
import { FUNNELS } from '../lib/links.mjs'
import ExtLink from './ExtLink.astro'
import FunnelLink from './FunnelLink.astro'
const { topic, context = '', tip = '', open = false, eduwill = false } = Astro.props
---
<section class="study-guide" aria-label="학습 안내">
  <div class="sg-learn">
    <p class="sg-eyebrow">이 강에서 배우는 것</p>
    <p class="sg-topic">🎯 <b>{topic}</b></p>
    {context && <p class="sg-context">📚 {context}</p>}
    <p class="sg-note">이 슬라이드 한 벌로 위 주제의 핵심을 익혀요. 시험에 자주 나오는 부분이니 처음부터 끝까지 넘겨보세요.</p>
  </div>

  <details class="sg-how" open={open}>
    <summary>
      <span class="sg-sum-ico">📖</span>
      <span class="sg-sum-txt">슬라이드만으로 공부하는 법</span>
      <span class="sg-sum-tag">5단계 · 펼쳐보기</span>
    </summary>
    <ol class="sg-steps">
      <li><b>훑어보기</b> — 먼저 처음부터 끝까지 빠르게 한 번 넘기며 전체 흐름을 잡으세요. 모르는 게 나와도 일단 통과.</li>
      <li><b>꼼꼼히 보기</b> — 다시 한 장씩 천천히 보며 핵심 용어와 그림을 눈에 익혀요.</li>
      <li><b>덮고 설명하기</b> — 슬라이드를 덮고 방금 본 내용을 한두 문장으로 직접 말해보세요. 막히면 그 슬라이드로 돌아가요.</li>
      <li><b>반복하기</b> — 자격증은 반복이 실력입니다. 하루 뒤·일주일 뒤 한 번씩 다시 넘겨보세요.</li>
      <li><b>표시하기</b> — 다 봤으면 위의 <b>‘읽음’</b>을 눌러 진도를 남기세요. 다음에 ‘이어보기’로 돌아올 수 있어요.</li>
    </ol>
    {tip && (
      <p class="sg-tip"><span class="sg-tip-ico">💡</span><span>{tip}</span></p>
    )}
    <div class="sg-next">
      <p class="sg-next-lead">📌 개념을 잡았으면, 다음은 <b>문제 풀이</b>예요.</p>
      <p class="sg-next-body">자격증은 결국 문제를 반복해서 푸는 만큼 붙습니다. 틀린 유형만 골라 다시 풀게 해주는 <FunnelLink funnel={FUNNELS.klue} class="sg-klue" badge={false}>Klue</FunnelLink>{FUNNELS.klue.comingSoon && '(준비중)'}로 약점을 메워보세요.{eduwill && (<> 더 깊은 강의가 필요하면 <ExtLink class="sg-eduwill" href={FUNNELS.eduwill.url}>에듀윌 온라인강의</ExtLink>도 참고할 수 있어요.</>)}</p>
    </div>
  </details>
</section>

<style>
  .study-guide { margin: var(--sp-5) 0; display: grid; gap: var(--sp-3); }

  .sg-learn {
    padding: var(--sp-4) var(--sp-5);
    border: 1px solid var(--brand-tint-bd); border-radius: var(--r-lg);
    background: var(--brand-tint);
  }
  .sg-eyebrow {
    font-size: var(--fs-xs); font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-snug); text-transform: uppercase;
    color: var(--brand-text); margin: 0 0 8px;
  }
  .sg-topic { font-size: var(--fs-h4, 1.15rem); color: var(--text-strong); margin: 0; line-height: var(--lh-tight); }
  .sg-topic b { font-weight: var(--fw-bold); }
  .sg-context { font-size: var(--fs-sm); color: var(--text-muted); margin: 6px 0 0; }
  .sg-note { font-size: var(--fs-sm); color: var(--text-default); margin: 10px 0 0; line-height: var(--lh-relaxed, 1.6); }

  .sg-how { border: 1px solid var(--border-default); border-radius: var(--r-lg); background: var(--surface-card); overflow: hidden; }
  .sg-how > summary {
    list-style: none; cursor: pointer; user-select: none;
    display: flex; align-items: center; gap: 10px;
    padding: 13px var(--sp-4); background: var(--surface-subtle);
    font-weight: var(--fw-semibold); color: var(--text-strong); font-size: var(--fs-body);
  }
  .sg-how > summary::-webkit-details-marker { display: none; }
  .sg-sum-ico { font-size: 17px; line-height: 1; }
  .sg-sum-tag { margin-left: auto; font-size: var(--fs-xs); font-weight: var(--fw-medium); color: var(--brand-text); white-space: nowrap; }
  .sg-how[open] > summary { border-bottom: 1px solid var(--border-default); }

  .sg-steps { margin: 0; padding: var(--sp-4) var(--sp-5) var(--sp-4) calc(var(--sp-5) + 18px); display: grid; gap: 10px; }
  .sg-steps li { font-size: var(--fs-sm); color: var(--text-default); line-height: var(--lh-relaxed, 1.6); }
  .sg-steps li b { color: var(--text-strong); font-weight: var(--fw-semibold); }
  .sg-steps li::marker { color: var(--brand); font-weight: var(--fw-bold); }

  .sg-tip {
    display: grid; grid-template-columns: 20px 1fr; gap: 10px;
    margin: 0 var(--sp-4) var(--sp-4); padding: var(--sp-3) var(--sp-4);
    border-radius: var(--r-md); background: var(--info-bg); border: 1px solid var(--info-border);
    font-size: var(--fs-sm); color: var(--text-default); line-height: var(--lh-relaxed, 1.6);
  }
  .sg-tip-ico { line-height: 1.4; }

  /* 개념(슬라이드) → 반복 문제풀이(Klue) 로 잇는 학습 동선 넛지 */
  .sg-next {
    margin: 0 var(--sp-4) var(--sp-4); padding: var(--sp-4);
    border-radius: var(--r-md); border: 1px solid var(--brand-tint-bd); background: var(--brand-tint);
  }
  .sg-next-lead { margin: 0; font-size: var(--fs-sm); font-weight: var(--fw-semibold); color: var(--text-strong); }
  .sg-next-body { margin: 6px 0 0; font-size: var(--fs-sm); color: var(--text-default); line-height: var(--lh-relaxed, 1.6); }
  .sg-klue { color: var(--brand-text); font-weight: var(--fw-semibold); text-decoration: underline; text-underline-offset: 2px; }
  .sg-klue:hover { text-decoration: none; }
  .sg-eduwill { color: var(--text-muted); text-decoration: underline; text-underline-offset: 2px; }
  .sg-eduwill:hover { color: var(--text-default); }
</style>
