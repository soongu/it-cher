---
// 코딩 토픽(과목) 카드 — 카드 하단에 [뭘 배우나요?] + [시작하기 →] 듀얼 CTA(비전공 제1원칙).
// HubCard(카드 전체가 <a>)와 달리, 여기선 카드 본문을 링크로 감싸지 않는다:
//   <button>(모달 열기)을 <a> 안에 넣는 건 잘못된 HTML(중첩 인터랙티브)이라, 명시적 CTA 2개로 분리한다.
// '뭘 배우나요?'는 같은 페이지의 WhatIsModal(data-whatis-modal id=whatisId)을 연다 — whatis 없으면 버튼 숨김(graceful).
// 카드 시각 구조(.cat-card/.cat-top/.cat-ico/.cat-title…)는 HubCard·doc.css 와 동일 클래스를 재사용한다.
import Glyph from './Glyph.astro'
const { href, icon, glyph = 'code', title, status = 'live', meta, cool = true, whatisId = null, startLabel = '시작하기' } = Astro.props
---
<article class="card cat-card cat-card--topic">
  <div class="cat-top">
    <div class:list={['cat-ico', { 'is-cool': cool, 'has-logo': !!icon }]}>
      {icon ? <img src={icon} alt={title} width="26" height="26" loading="lazy" /> : <Glyph name={glyph} />}
    </div>
    {status === 'live'
      ? <span class="badge badge--live"><span class="dot"></span>운영</span>
      : <span class="badge badge--planned"><span class="dot"></span>예정</span>}
  </div>
  <div class="cat-body">
    <div class="cat-title">{title}</div>
    {meta && <div class="cat-meta">{meta}</div>}
  </div>
  <div class="cat-cta">
    {whatisId && (
      <button type="button" class="btn btn--secondary btn--sm whatis-trigger"
        data-whatis-open={whatisId} aria-haspopup="dialog">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M9.5 9a2.5 2.5 0 1 1 3.5 2.3c-.7.4-1 .8-1 1.7"/><path d="M12 17h.01"/></svg>
        뭘 배우나요?
      </button>
    )}
    <a class="btn btn--sm whatis-start" href={href}>{startLabel} <span aria-hidden="true">→</span></a>
  </div>
</article>
