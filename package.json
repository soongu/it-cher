{
  "name": "lecture-site",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "정보처리기사·SQLD·백엔드 강의교안 통합 정적 사이트 (PoC)",
  "scripts": {
    "sync": "node scripts/sync-decks.mjs",
    "dev": "npm run sync && astro dev",
    "build": "npm run sync && astro build && npm run index",
    "index": "pagefind --site dist",
    "verify": "node scripts/verify-build.mjs",
    "lint:images": "node scripts/lint-images.mjs",
    "check": "npm run build && npm run verify",
    "preview": "astro preview",
    "deploy": "npm run check && node scripts/deploy.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^5.6.1",
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "pagefind": "^1.5.2"
  }
}
